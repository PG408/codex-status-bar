      },
      "expect": {
        "sessions": {
          "subagent": {
            "state": "thinking",
            "label": "Subagent running",
            "activity": "subagent",
            "tool": "Bash",
            "turnId": "sub-turn",
            "started": true
          }
        },
        "lead": "subagent"
      }
    },
    {
      "event": "PreCompact",
      "payload": {
        "session_id": "subagent",
        "turn_id": "sub-turn",
        "cwd": "/tmp/subagent-project",
        "agent_id": "agent-1",
        "agent_type": "explorer"
      },
      "expect": {
        "sessions": {
          "subagent": {
            "state": "thinking",
            "label": "Subagent running",
            "activity": "subagent",
            "turnId": "sub-turn",
            "started": true
          }
        },
        "lead": "subagent"
      }
    },
    {
      "event": "PostCompact",
      "payload": {
        "session_id": "subagent",
        "turn_id": "sub-turn",
        "cwd": "/tmp/subagent-project",
        "agent_id": "agent-1",
        "agent_type": "explorer"
      },
      "expect": {
        "sessions": {
