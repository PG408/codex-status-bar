{
  "name": "subagent-turn",
  "description": "SubagentStart/SubagentStop 应形成可见的单状态文件转移。",
  "steps": [
    {
      "event": "SubagentStart",
      "payload": {
        "session_id": "session-subagent",
        "turn_id": "turn-subagent",
        "cwd": "/tmp/subagent-project"
      },
      "expect": {
        "state": "thinking",
        "label": "Codex thinking",
        "sessionId": "session-subagent",
        "activeSessionId": "session-subagent",
        "activeTurnId": "turn-subagent",
        "project": "subagent-project"
      }
    },
    {
      "event": "SubagentStop",
      "payload": {
        "session_id": "session-subagent",
        "turn_id": "turn-subagent",
        "cwd": "/tmp/subagent-project"
      },
      "expect": {
        "state": "done",
        "label": "Done",
        "startedAt": 0,
        "sessionId": "session-subagent"
      }
    }
  ]
}
