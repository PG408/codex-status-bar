            "turnId": "main-turn",
            "started": true
          }
        },
        "lead": "priority"
      }
    },
    {
      "event": "PreToolUse",
      "payload": {
        "session_id": "priority",
        "turn_id": "main-turn",
        "cwd": "/tmp/priority-project",
