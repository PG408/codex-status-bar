{
  "name": "subagent-priority-session",
  "description": "Single-session aggregation keeps main activity authoritative while subagents start and stop.",
  "steps": [
    {
      "event": "UserPromptSubmit",
      "payload": {
        "session_id": "priority",
        "turn_id": "main-turn",
        "cwd": "/tmp/priority-project"
      },
      "expect": {
        "sessions": {
          "priority": {
            "state": "thinking",
            "label": "Thinking...",
            "activity": "",
            "turnId": "main-turn",
            "started": true
          }
        },
        "lead": "priority"
      }
    },
    {
      "event": "SubagentStart",
      "payload": {
        "session_id": "priority",
        "turn_id": "sub-turn-a",
        "cwd": "/tmp/priority-project",
        "agent_id": "agent-a",
        "agent_type": "explorer"
      },
      "expect": {
        "sessions": {
          "priority": {
            "state": "thinking",
            "label": "Subagent running",
            "activity": "subagent",
            "turnId": "main-turn",
            "started": true
          }
        },
        "lead": "priority"
      }
    },
    {
      "event": "SubagentStop",
      "payload": {
        "session_id": "priority",
        "turn_id": "sub-turn-a",
        "cwd": "/tmp/priority-project",
