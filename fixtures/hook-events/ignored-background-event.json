{
  "name": "ignored-background-event",
  "description": "非 active turn 的工具事件不能覆盖当前 active turn。",
  "steps": [
    {
      "event": "UserPromptSubmit",
      "payload": {
        "session_id": "session-active",
        "turn_id": "turn-active",
        "cwd": "/tmp/active-project"
      },
      "expect": {
        "state": "thinking",
        "activeSessionId": "session-active",
        "activeTurnId": "turn-active",
        "project": "active-project"
      }
    },
    {
      "event": "PreToolUse",
      "payload": {
        "session_id": "session-background",
        "turn_id": "turn-background",
        "cwd": "/tmp/background-project",
        "tool_name": "Read"
      },
      "expect": {
        "state": "thinking",
        "activeSessionId": "session-active",
        "activeTurnId": "turn-active",
        "project": "active-project"
      }
    }
  ]
}
