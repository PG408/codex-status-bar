{
  "name": "compacting-session",
  "description": "Context compaction is shown as a first-class active state and returns to thinking after PostCompact.",
  "steps": [
    {
      "event": "UserPromptSubmit",
      "payload": {
        "session_id": "compact",
        "turn_id": "compact-turn",
        "cwd": "/tmp/compact-project"
      },
      "expect": {
        "sessions": {
          "compact": {
            "state": "thinking",
            "label": "Thinking...",
            "sessionId": "compact",
            "turnId": "compact-turn",
            "project": "compact-project",
            "started": true
          }
        },
        "lead": "compact"
      }
    },
    {
      "event": "PreCompact",
      "payload": {
        "session_id": "compact",
        "turn_id": "compact-turn",
        "cwd": "/tmp/compact-project"
      },
      "expect": {
        "sessions": {
          "compact": {
            "state": "compacting",
            "label": "Compacting",
            "tool": "",
            "turnId": "compact-turn",
            "started": true
          }
        },
        "lead": "compact"
      }
    },
    {
      "event": "PostCompact",
      "payload": {
        "session_id": "compact",
        "turn_id": "compact-turn",
        "cwd": "/tmp/compact-project"
      },
      "expect": {
        "sessions": {
          "compact": {
            "state": "thinking",
            "label": "Thinking...",
            "turnId": "compact-turn",
            "started": true
          }
        },
        "lead": "compact"
      }
    }
  ]
}
